    "Auto always uses the best voice you have installed. Download a Premium voice and Auto upgrades instantly — no selection needed." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Auto siempre usa la mejor voz instalada. Descarga una voz Premium y Auto mejora al instante."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Auto utilise toujours la meilleure voix installée. Téléchargez une voix Premium et Auto s'améliore instantanément."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Auto sempre usa a melhor voz instalada. Baixe uma voz Premium e o Auto melhora instantaneamente."
