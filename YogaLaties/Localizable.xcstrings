{
  "sourceLanguage" : "en",
  "strings" : {
    "\"%@\" complete" : {
      "comment" : "A title that indicates that the user has completed a yoga routine. The argument is the name of the routine that has been completed.",
      "isCommentAutoGenerated" : true
    },
    "\"Calm\" (~0.40) works well for yoga. Adjust until it feels right for you." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«Calma» (~0,40) funciona bien para yoga. Ajusta hasta que se sienta bien."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« Calme » (~0,40) convient bien au yoga. Ajustez jusqu'à ce que ce soit confortable."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«Calmo» (~0,40) funciona bem para yoga. Ajuste até se sentir confortável."
          }
        }
      }
    },
    "\"Neutral\" is the default. Lower values feel more meditative; higher values feel more energising." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«Neutro» es el valor por defecto. Los valores bajos son más meditativos; los altos, más energizantes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« Neutre » est le réglage par défaut. Les valeurs basses sont plus méditatives ; les valeurs hautes sont plus énergisantes."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«Neutro» é o padrão. Valores mais baixos são mais meditativos; valores mais altos são mais energizantes."
          }
        }
      }
    },
    "%lld" : {
      "comment" : "A label that displays the number of seconds remaining in an exercise session.",
      "isCommentAutoGenerated" : true
    },
    "%lld  ·  %@" : {
      "comment" : "A count and duration of exercises in a routine. The argument is the string “%arg sec total”, the string “%arg min total”, or the string “%1$arg min %2$arg sec total”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld  ·  %2$@"
          }
        }
      }
    },
    "%lld English voices" : {
      "comment" : "A label showing the number of English voices available. The argument is the count of available voices.",
      "isCommentAutoGenerated" : true
    },
    "%lld of %lld" : {
      "comment" : "A step counter for exercises.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
